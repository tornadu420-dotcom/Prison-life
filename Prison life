		local mouseX = mouse.X
		
		local percent = math.clamp((mouseX - sliderPos) / sliderSize, 0, 1)
		local newSpeed = math.floor(CFG.FlySpeedMin + (CFG.FlySpeedMax - CFG.FlySpeedMin) * percent)
		
		CFG.FlySpeed = newSpeed
		UpdateFlySpeedSlider()
	end
