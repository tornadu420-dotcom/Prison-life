-- ESP CORRIGIDO POR TIME

local function CreateESPForPlayer(targetPlayer)
	if targetPlayer == LP then return end
	if ESPCache[targetPlayer] then return end

	local box = Drawing.new("Square")  
	box.Color = GetESPColor(targetPlayer)
	box.Thickness = 2  
	box.Filled = false  
	box.Visible = false  

	local nametag = Drawing.new("Text")  
	nametag.Color = GetESPColor(targetPlayer)
	nametag.Size = 16  
	nametag.Center = true  
	nametag.Outline = true  
	nametag.Font = 2  
	nametag.Visible = false  

	local distText = Drawing.new("Text")  
	distText.Color = GetESPColor(targetPlayer)
	distText.Size = 14  
	distText.Center = true  
	distText.Outline = true  
	distText.Font = 2  
	distText.Visible = false  

	local healthBar = Drawing.new("Square")  
	healthBar.Color = Color3.fromRGB(255, 0, 0)  
	healthBar.Thickness = 1  
	healthBar.Filled = true  
	healthBar.Visible = false  

	local healthBarBG = Drawing.new("Square")  
	healthBarBG.Color = Color3.fromRGB(50, 50, 50)  
	healthBarBG.Thickness = 1  
	healthBarBG.Filled = true  
	healthBarBG.Visible = false  

	local healthText = Drawing.new("Text")
	healthText.Color = Color3.fromRGB(255, 255, 255)
	healthText.Size = 12
	healthText.Outline = true
	healthText.Font = 2
	healthText.Visible = false

	ESPCache[targetPlayer] = {
		box = box,
		nametag = nametag,
		distText = distText,
		healthBar = healthBar,
		healthBarBG = healthBarBG,
		healthText = healthText,
		stepped = nil
	}

	local function UpdateESP()
		if not CFG.ESP then
			box.Visible = false
			nametag.Visible = false
			distText.Visible = false
			healthBar.Visible = false
			healthBarBG.Visible = false
			healthText.Visible = false
			return
		end

		if not targetPlayer or not targetPlayer.Character then return end

		local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
		local head = targetPlayer.Character:FindFirstChild("Head")
		local humanoid = targetPlayer.Character:FindFirstChild("Humanoid")

		if not root or not head or not humanoid or humanoid.Health <= 0 then
			box.Visible = false
			nametag.Visible = false
			distText.Visible = false
			healthBar.Visible = false
			healthBarBG.Visible = false
			healthText.Visible = false
			return
		end

		if not IsEnemy(targetPlayer) then
			box.Visible = false
			nametag.Visible = false
			distText.Visible = false
			healthBar.Visible = false
			healthBarBG.Visible = false
			healthText.Visible = false
			return
		end

		local rootPos, rootOnScreen = Camera:WorldToViewportPoint(root.Position)
		local headPos, headOnScreen = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))

		if rootOnScreen and headOnScreen then
			local height = math.abs(headPos.Y - rootPos.Y) * 2  
			local width = height / 1.6  

			local espColor = GetESPColor(targetPlayer)
			box.Color = espColor
			nametag.Color = espColor
			distText.Color = espColor

			box.Size = Vector2.new(width, height)  
			box.Position = Vector2.new(rootPos.X - width / 2, rootPos.Y - height / 2)  
			box.Visible = true  

			local teamTag = targetPlayer.Team and targetPlayer.Team.Name or "Unknown"
			nametag.Position = Vector2.new(rootPos.X, rootPos.Y - height / 2 - 20)  
			nametag.Text = targetPlayer.Name .. " [" .. teamTag .. "]"
			nametag.Visible = true  

			local dist = (LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") and (LP.Character.HumanoidRootPart.Position - root.Position).Magnitude) or 0
			distText.Position = Vector2.new(rootPos.X, rootPos.Y + height / 2 + 8)
			distText.Text = string.format("%.1f m", dist / 3)
			distText.Visible = true

			local healthPercent = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
			local barWidth = 5  
			local barHeight = height  
			local barX = rootPos.X - width / 2 - barWidth - 5  
			local barY = rootPos.Y - height / 2  

			healthBarBG.Size = Vector2.new(barWidth, barHeight)  
			healthBarBG.Position = Vector2.new(barX, barY)  
			healthBarBG.Visible = true  

			healthBar.Size = Vector2.new(barWidth, barHeight * healthPercent)  
			healthBar.Position = Vector2.new(barX, barY + (barHeight * (1 - healthPercent)))  
			healthBar.Color = healthPercent > 0.5 and Color3.fromRGB(0, 255, 0) or healthPercent > 0.25 and Color3.fromRGB(255, 255, 0) or Color3.fromRGB(255, 0, 0)  
			healthBar.Visible = true  

			healthText.Position = Vector2.new(barX - 15, barY + barHeight / 2)
			healthText.Text = string.format("%.0f/%.0f", humanoid.Health, humanoid.MaxHealth)
			healthText.Visible = true
		else  
			box.Visible = false  
			nametag.Visible = false  
			distText.Visible = false
			healthBar.Visible = false  
			healthBarBG.Visible = false  
			healthText.Visible = false
		end  
	end

	ESPCache[targetPlayer].stepped = RunService.RenderStepped:Connect(UpdateESP)

	targetPlayer.AncestryChanged:Connect(function(_, parent)
		if parent == nil then
			if ESPCache[targetPlayer] then
				box:Remove()
				nametag:Remove()
				distText:Remove()
				healthBar:Remove()
				healthBarBG:Remove()
				healthText:Remove()
				if ESPCache[targetPlayer].stepped then
					ESPCache[targetPlayer].stepped:Disconnect()
				end
				ESPCache[targetPlayer] = nil
			end
		end
	end)

	targetPlayer.Changed:Connect(function(prop)
		if prop == "Team" then
			local newColor = GetESPColor(targetPlayer)
			box.Color = newColor
			nametag.Color = newColor
			distText.Color = newColor
		end
	end)

end

for _, plr in pairs(Players:GetPlayers()) do
	if plr ~= LP then
		CreateESPForPlayer(plr)
	end
end

Players.PlayerAdded:Connect(function(plr)
	if plr ~= LP then
		task.wait(0.5)
		CreateESPForPlayer(plr)
	end
end)

