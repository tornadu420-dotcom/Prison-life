function UpdateFlySpeedSlider()
	local percent = (CFG.FlySpeed - CFG.FlySpeedMin) / (CFG.FlySpeedMax - CFG.FlySpeedMin)
	sliderFill.Size = UDim2.new(percent, 0, 1, 0)
	sliderThumb.Position = UDim2.new(percent, -9, 0.5, -9)
